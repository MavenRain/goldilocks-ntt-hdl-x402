# Cargo build artifacts.  `**/target/` catches both the workspace
# root target and the worker/target/ created when worker-build is run
# with CARGO_TARGET_DIR=target from inside worker/.
**/target/
**/*.rs.bk
.DS_Store

# Cloudflare Workers
.wrangler/
.dev.vars
node_modules/

# Anchor
.anchor/
test-ledger/

# Verilator-WASM build artifacts
/scripts/build/
*.wasm
!worker/src/backend/ntt_rtl.wasm.placeholder
